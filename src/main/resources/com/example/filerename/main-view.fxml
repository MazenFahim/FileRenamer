<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="rootStack"
           stylesheets="@styles.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.filerename.controller.MainController">

    <BorderPane styleClass="app-layout">
        <center>
            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        pannable="true"
                        vbarPolicy="AS_NEEDED"
                        styleClass="content-scroll">
                <content>
                    <VBox fx:id="contentContainer" styleClass="app-shell">
                        <FlowPane alignment="CENTER_LEFT" hgap="14.0" vgap="10.0" styleClass="header">
                            <HBox alignment="CENTER_LEFT" spacing="14.0">
                                <StackPane minHeight="48.0" minWidth="48.0" prefHeight="48.0" prefWidth="48.0"
                                           styleClass="logo-container">
                                    <SVGPath content="M4 5.5A2.5 2.5 0 0 1 6.5 3H11l2 2h4.5A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5z M9 10h6 M12 7v6"
                                             styleClass="logo-mark"/>
                                </StackPane>

                                <VBox spacing="2.0">
                                    <Label text="FileRenamer" styleClass="app-title"/>
                                    <Label text="Organize your project assets in seconds" styleClass="app-subtitle"/>
                                </VBox>
                            </HBox>

                            <Label text="SAFE TWO-STAGE RENAME" styleClass="security-badge"/>
                        </FlowPane>

                        <VBox fx:id="dropZone"
                              alignment="CENTER"
                              onDragDropped="#handleDrop"
                              onDragExited="#handleDragExited"
                              onDragOver="#handleDragOver"
                              spacing="9.0"
                              styleClass="drop-zone">
                            <StackPane minHeight="48.0" minWidth="48.0" styleClass="drop-icon-container">
                                <SVGPath content="M12 3v11 M8 7l4-4 4 4 M5 13v5h14v-5"
                                         styleClass="drop-icon"/>
                            </StackPane>
                            <Label text="Drop files here" styleClass="drop-title"/>
                            <Label text="or browse from your computer" styleClass="drop-subtitle"/>
                            <Button fx:id="browseButton"
                                    mnemonicParsing="false"
                                    onAction="#handleBrowse"
                                    text="Browse Files"
                                    styleClass="secondary-button"/>
                        </VBox>

                        <VBox spacing="16.0" styleClass="card settings-card">
                            <FlowPane alignment="CENTER_LEFT" hgap="16.0" vgap="10.0">
                                <VBox spacing="3.0">
                                    <Label text="Rename settings" styleClass="section-title"/>
                                    <Label text="Build a predictable naming sequence before changing anything."
                                           wrapText="true"
                                           styleClass="section-subtitle"/>
                                </VBox>
                                <Label fx:id="exampleLabel" text="Preview: Hero01.png" styleClass="example-preview"/>
                            </FlowPane>

                            <FlowPane hgap="18.0" vgap="14.0">
                                <VBox prefWidth="300.0" spacing="7.0">
                                    <Label text="Filename prefix" styleClass="field-label"/>
                                    <TextField fx:id="prefixField" promptText="e.g. Hero" text="Hero"/>
                                </VBox>

                                <VBox prefWidth="200.0" spacing="7.0">
                                    <Label text="Starting number" styleClass="field-label"/>
                                    <Spinner fx:id="startNumberSpinner" prefWidth="200.0"/>
                                </VBox>

                                <VBox prefWidth="200.0" spacing="7.0">
                                    <Label text="Number padding" styleClass="field-label"/>
                                    <ComboBox fx:id="paddingCombo" prefWidth="200.0" promptText="Select padding"/>
                                </VBox>
                            </FlowPane>

                            <Label fx:id="validationLabel"
                                   managed="false"
                                   text="Validation message"
                                   visible="false"
                                   wrapText="true"
                                   styleClass="validation-message"/>
                        </VBox>

                        <VBox spacing="12.0" styleClass="card table-card">
                            <VBox spacing="3.0">
                                <Label text="File preview" styleClass="section-title"/>
                                <Label text="Review every destination before running the rename."
                                       wrapText="true"
                                       styleClass="section-subtitle"/>
                            </VBox>

                            <TableView fx:id="fileTable">
                                <columns>
                                    <TableColumn fx:id="originalColumn" minWidth="120.0" prefWidth="260.0"
                                                 text="ORIGINAL NAME"/>
                                    <TableColumn fx:id="newColumn" minWidth="120.0" prefWidth="250.0"
                                                 text="NEW NAME"/>
                                    <TableColumn fx:id="typeColumn" minWidth="60.0" prefWidth="80.0"
                                                 text="TYPE"/>
                                    <TableColumn fx:id="sizeColumn" minWidth="65.0" prefWidth="90.0"
                                                 text="SIZE"/>
                                    <TableColumn fx:id="statusColumn" minWidth="90.0" prefWidth="120.0"
                                                 text="STATUS"/>
                                    <TableColumn fx:id="actionColumn" maxWidth="52.0" minWidth="52.0"
                                                 prefWidth="52.0" resizable="false" text=""/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>

        <bottom>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="footer-actions">
                <Label fx:id="selectedCountLabel" text="0 files selected" styleClass="selected-count"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearButton"
                        mnemonicParsing="false"
                        onAction="#handleClear"
                        text="Clear"
                        styleClass="ghost-button"/>
                <Button fx:id="renameButton"
                        mnemonicParsing="false"
                        onAction="#handleRename"
                        styleClass="primary-button">
                    <graphic>
                        <HBox alignment="CENTER" spacing="9.0">
                            <ProgressIndicator fx:id="renameProgress"
                                               managed="false"
                                               maxHeight="17.0"
                                               maxWidth="17.0"
                                               minHeight="17.0"
                                               minWidth="17.0"
                                               prefHeight="17.0"
                                               prefWidth="17.0"
                                               visible="false"/>
                            <Label fx:id="renameButtonText" text="Rename Files"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>
        </bottom>
    </BorderPane>

    <AnchorPane pickOnBounds="false">
        <children>
            <HBox fx:id="toastContainer"
                  alignment="CENTER_LEFT"
                  managed="false"
                  minHeight="58.0"
                  minWidth="320.0"
                  prefWidth="380.0"
                  maxWidth="440.0"
                  spacing="12.0"
                  visible="false"
                  AnchorPane.rightAnchor="20.0"
                  AnchorPane.topAnchor="20.0"
                  styleClass="toast toast-info">
                <Region minHeight="34.0" minWidth="4.0" prefHeight="34.0" prefWidth="4.0"
                        maxHeight="34.0" maxWidth="4.0" styleClass="toast-accent"/>
                <Label fx:id="toastIcon" text="i" styleClass="toast-icon"/>
                <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="toastTitle" text="Notice" styleClass="toast-title"/>
                    <Label fx:id="toastLabel" maxWidth="330.0" text="Notification" wrapText="true"
                           styleClass="toast-text"/>
                </VBox>
            </HBox>
        </children>
    </AnchorPane>
</StackPane>
